# ─────────────────────────────────────────────────────────────
# Wingman environment variables
# Copy to .env.local for local dev. Set the same keys in
# Netlify > Site settings > Environment variables for production.
# NEVER commit real values — .env.local is gitignored.
# ─────────────────────────────────────────────────────────────

# ── Client (Vite — exposed to the browser, must be public-safe) ──
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# ── Stripe (server-only — Netlify functions) ───────────────────
# Secret key: Stripe Dashboard > Developers > API keys
STRIPE_API_KEY=sk_live_or_test_xxx
# Webhook signing secret: Stripe Dashboard > Developers > Webhooks
# Endpoint: https://YOUR-SITE.netlify.app/.netlify/functions/stripe-webhook
# Event: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── Supabase service role (server-only — Netlify functions) ─────
# Bypasses RLS; used by stripe-webhook + capture-lead to write data.
# Supabase Dashboard > Project Settings > API > service_role key.
# DO NOT prefix with VITE_ and DO NOT expose to the client.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# ── Admin dashboard access (server-only) ───────────────────────
# Comma-separated allowlist of emails permitted to view the admin
# "Live" data (confirmed bookings + leads). A user must be logged in
# via Supabase AND have their email listed here.
ADMIN_EMAILS=you@example.com

# ── Resend (server-only — welcome email) ───────────────────────
RESEND_API_KEY=re_xxx
RESEND_FROM=WINGMAN Miami <onboarding@wingman-app.com>

# ── Optional: extra CORS origins (comma-separated) ─────────────
# ALLOWED_ORIGINS=https://staging.wingman-app.com
