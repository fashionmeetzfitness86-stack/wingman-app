# ─── WINGMAN APP — Environment Variables ──────────────────────────────────────
# Copy this file to .env.local for local development.
# Set these in Netlify → Site Settings → Environment Variables for production.
#
# NEVER commit .env.local or any file containing real values to git.
# ──────────────────────────────────────────────────────────────────────────────

# ── Supabase (Auth) ────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Stripe (Payments) ──────────────────────────────────────────────────────────
# Get the secret key from: https://dashboard.stripe.com/apikeys
# Use sk_test_... for development, sk_live_... for production.
# Set in Netlify env vars ONLY — never in .env.local for production.
STRIPE_SECRET_KEY=

# ── Stripe Webhook Signing Secret ─────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/webhooks → your endpoint → Signing secret
# Required for stripe-webhook.ts to verify incoming webhook events.
STRIPE_WEBHOOK_SECRET=

# ── Optional: Stripe API key alias (fallback key names checked in create-checkout.ts) ──
# The function checks: STRIPE_API_KEY → STRIPE_SECRET_KEY → STRIPE_KEY (in that order)
# Only set one of these.
# STRIPE_API_KEY=
# STRIPE_KEY=
